{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true, // 1. Skips checking types in node_modules
    "moduleResolution": "nodenext", // 2. Ensures TS finds packages correctly
    "resolveJsonModule": true // 3. Useful if you import config JSONs
  },
  "exclude": ["src/**/*.test.ts"],
  "include": ["src", "callback", "connect"]
}
